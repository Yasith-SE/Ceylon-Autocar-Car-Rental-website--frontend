# REST backend base URL
VITE_API_BASE_URL=http://localhost:8091/api

# Google Maps browser API key for rental location autocomplete and route preview
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key_here

# Support chat websocket endpoint for customer to admin live chat
VITE_SUPPORT_CHAT_WS_URL=ws://localhost:8091/ws/support-chat
